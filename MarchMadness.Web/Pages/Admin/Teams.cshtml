@page
@model MarchMadness.Web.Pages.Admin.TeamsModel
@{
    ViewData["Title"] = "Manage Teams";
}

<div class="container mt-4">
    <h1>Manage Teams</h1>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h3>Add New Team</h3>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="AddTeam">
                        <div class="mb-3">
                            <label asp-for="NewTeam.Name" class="form-label">Team Name</label>
                            <input asp-for="NewTeam.Name" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewTeam.Seed" class="form-label">Seed (1-16)</label>
                            <input asp-for="NewTeam.Seed" type="number" min="1" max="16" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewTeam.Region" class="form-label">Region</label>
                            <select asp-for="NewTeam.Region" class="form-select" required>
                                <option value="">-- Select Region --</option>
                                <option value="East">East</option>
                                <option value="West">West</option>
                                <option value="South">South</option>
                                <option value="Midwest">Midwest</option>
                            </select>
                        </div>
                        <div class="mb-3 form-check">
                            <input asp-for="NewTeam.IsActive" type="checkbox" class="form-check-input" checked />
                            <label asp-for="NewTeam.IsActive" class="form-check-label">Active</label>
                        </div>
                        <button type="submit" class="btn btn-primary">Add Team</button>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <form method="post" asp-page-handler="AssignTeamsToGames" onsubmit="return confirm('This will assign teams to Round 1 games. Continue?');">
                        <button type="submit" class="btn btn-success btn-lg w-100">
                            Auto-Assign Teams to Round 1 Games
                        </button>
                        <p class="text-muted mt-2 small">
                            This will automatically set up the tournament bracket using standard NCAA matchups (1v16, 8v9, etc.)
                        </p>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h3>Current Teams</h3>
                </div>
                <div class="card-body">
                    @if (!Model.Teams.Any())
                    {
                        <p class="text-muted">No teams added yet.</p>
                    }
                    else
                    {
                        @foreach (var region in new[] { "East", "West", "South", "Midwest" })
                        {
                            var regionTeams = Model.Teams.Where(t => t.Region == region).ToList();
                            if (regionTeams.Any())
                            {
                                <h4 class="mt-3">@region Region</h4>
                                <div class="list-group mb-3">
                                    @foreach (var team in regionTeams)
                                    {
                                        <div class="list-group-item d-flex justify-content-between align-items-center">
                                            <span>
                                                <strong>@team.Seed.</strong> @team.Name
                                                @if (!team.IsActive)
                                                {
                                                    <span class="badge bg-secondary">Inactive</span>
                                                }
                                            </span>
                                            <form method="post" asp-page-handler="DeleteTeam" asp-route-id="@team.Id" 
                                                  onsubmit="return confirm('Delete @team.Name?');" style="display:inline;">
                                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
