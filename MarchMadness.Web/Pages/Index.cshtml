@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center mt-5">
    <h1 class="display-3">March Madness Tournament</h1>
    <p class="lead">Fill out brackets for both Men's and Women's Basketball and compete with your coworkers!</p>

    <div class="row mt-5 g-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3>Submit Brackets</h3>
                </div>
                <div class="card-body">
                    <p>Submit your predictions for the men's tournament</p>
                    <a href="/SubmitBracket?sport=basketball-women" role="button" class="btn btn-primary">Submit Women's Bracket</a>
                    <a href="/SubmitBracket?sport=basketball-men" role="button" class="btn btn-primary">Submit Men's Bracket</a>

                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100 border-info">
                <div class="card-header bg-info text-white">
                    <h3>View Standings</h3>
                </div>
                <div class="card-body">
                    <p>Submit your predictions for the women's tournament</p>
                    <a href="/Standings?sport=basketball-women" class="btn btn-outline-info">View Women's Standings</a>
                    <a href="/Standings?sport=basketball-men" class="btn btn-outline-primary">View Men's Standings</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <h3>How It Works</h3>
                    <div class="text-start">
                        <p><strong>Scoring System:</strong></p>
                        <ul>
                            <li>First Four / Round 1: <strong>1 point</strong> per correct pick</li>
                            <li>Round 2: <strong>2 points</strong></li>
                            <li>Round 3 (Sweet 16): <strong>4 points</strong></li>
                            <li>Round 4 (Elite Eight): <strong>8 points</strong></li>
                            <li>Round 5 (Final Four): <strong>16 points</strong></li>
                            <li>Championship: <strong>32 points</strong></li>
                        </ul>
                        <p class="text-muted">
                            Tournament data is automatically synchronized from the NCAA API. 
                            Scores and standings are updated as games complete.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        var adminUsers = new[] { "EVR\\sallen", "EVR\\sallen-t1" };
        if (adminUsers.Contains(User.Identity?.Name, StringComparer.OrdinalIgnoreCase))
        {
            <div class="alert alert-warning mt-5">
                <h4>Admin Controls</h4>
                <p>You have administrator access. Use the Admin page to sync tournament data and update scores.</p>
                <a href="/Admin/Sync" class="btn btn-warning">Go to Admin Panel</a>
            </div>
        }
    }
</div>
