@page
@model MarchMadness.Web.Pages.SubmitBracketModel
@{
    ViewData["Title"] = $"Submit {(Model.Sport == "basketball-men" ? "Men's" : "Women's")} Bracket";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@ViewData["Title"]</h1>
        <div class="btn-group">
            <a href="?sport=basketball-men" class="btn @(Model.Sport == "basketball-men" ? "btn-primary" : "btn-outline-primary")">Men's</a>
            <a href="?sport=basketball-women" class="btn @(Model.Sport == "basketball-women" ? "btn-info" : "btn-outline-info")">Women's</a>
        </div>
    </div>

    @if (!Model.HasGames)
    {
        <div class="alert alert-warning">
            <strong>Tournament not set up yet.</strong>
            <p>The bracket data needs to be synced from the API. Please contact an administrator.</p>
        </div>
    }
    else
    {
        <form method="post" id="bracketForm">
            <input type="hidden" asp-for="Sport" />
            
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UserName" class="form-label">Your Name</label>
                            <input asp-for="UserName" class="form-control" required />
                            <span asp-validation-for="UserName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="BracketName" class="form-label">Bracket Name (Optional)</label>
                            <input asp-for="BracketName" class="form-control" placeholder="e.g., 'My Best Picks'" />
                        </div>
                    </div>
                </div>
            </div>

            @foreach (var roundGames in Model.GamesByRound.OrderBy(r => r.Key))
            {
                var roundNumber = roundGames.Key;
                var roundName = roundNumber switch
                {
                    1 => "First Four",
                    2 => "First Round",
                    3 => "Second Round",
                    4 => "Sweet 16",
                    5 => "Elite Eight",
                    6 => "Final Four",
                    7 => "Championship",
                    _ => $"Round {roundNumber}"
                };

                var cardColor = roundNumber switch
                {
                    1 or 2 => "primary",
                    3 => "success",
                    4 => "warning",
                    5 => "danger",
                    6 or 7 => "dark",
                    _ => "secondary"
                };

                <div class="card mb-4">
                    <div class="card-header bg-@cardColor text-white">
                        <h3>@roundName</h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @foreach (var game in roundGames.Value)
                            {
                                <div class="col-md-6 col-lg-4 mb-3">
                                    <div class="card">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-2">
                                                <strong class="me-2">Game @game.BracketPositionId</strong>
                                                @if (game.StartTime.HasValue)
                                                {
                                                    <small class="text-muted">@game.StartTime.Value.ToString("MMM dd, h:mm tt")</small>
                                                }
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" 
                                                       name="GamePicks[@game.Id]" 
                                                       value="@game.Team1Id" 
                                                       id="game_@(game.Id)_team1" required>
                                                <label class="form-check-label d-flex align-items-center" for="game_@(game.Id)_team1">
                                                    @if (!string.IsNullOrEmpty(game.Team1?.LogoUrl))
                                                    {
                                                        <img src="https://ncaa.com@game.Team1.LogoUrl" alt="@game.Team1.NameShort" class="me-2" style="width: 20px; height: 20px;" onerror="this.style.display='none'" />
                                                    }
                                                    <span>
                                                        @if (game.Team1?.Seed > 0)
                                                        {
                                                            <strong>(@game.Team1.Seed)</strong>
                                                        }
                                                        @game.Team1?.NameShort
                                                    </span>
                                                </label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" 
                                                       name="GamePicks[@game.Id]" 
                                                       value="@game.Team2Id" 
                                                       id="game_@(game.Id)_team2" required>
                                                <label class="form-check-label d-flex align-items-center" for="game_@(game.Id)_team2">
                                                    @if (!string.IsNullOrEmpty(game.Team2?.LogoUrl))
                                                    {
                                                        <img src="https://ncaa.com@game.Team2.LogoUrl" alt="@game.Team2.NameShort" class="me-2" style="width: 20px; height: 20px;" onerror="this.style.display='none'" />
                                                    }
                                                    <span>
                                                        @if (game.Team2?.Seed > 0)
                                                        {
                                                            <strong>(@game.Team2.Seed)</strong>
                                                        }
                                                        @game.Team2?.NameShort
                                                    </span>
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <div class="d-grid gap-2 mb-5">
                <button type="submit" class="btn btn-lg @(Model.Sport == "basketball-men" ? "btn-primary" : "btn-info")">
                    Submit Bracket
                </button>
            </div>
        </form>
    }
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
