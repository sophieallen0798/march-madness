@page
@model MarchMadness.Web.Pages.SubmitBracketModel
@{
    ViewData["Title"] = "Submit Bracket";
}

<div class="container mt-4">
    <h1>Submit Your Bracket</h1>

    @if (!Model.Round1Games.Any(g => g.Team1Id.HasValue && g.Team2Id.HasValue))
    {
        <div class="alert alert-warning">
            <strong>Tournament not set up yet.</strong>
            <p>The administrator needs to add teams before you can submit brackets.</p>
        </div>
    }
    else
    {
        <form method="post" id="bracketForm">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UserName" class="form-label">Your Name</label>
                            <input asp-for="UserName" class="form-control" required />
                            <span asp-validation-for="UserName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="BracketName" class="form-label">Bracket Name (Optional)</label>
                            <input asp-for="BracketName" class="form-control" placeholder="e.g., 'My Best Picks'" />
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.Round1Games.Any(g => g.Team1Id.HasValue && g.Team2Id.HasValue))
            {
                <div class="alert alert-info">
                    <strong>How to fill out your bracket:</strong> Select the winner for each game in each round.
                </div>

                <!-- Round 1 -->
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h3>Round 1 - Round of 64</h3>
                    </div>
                    <div class="card-body">
                        @foreach (var region in new[] { "East", "West", "South", "Midwest" })
                        {
                            <h4 class="mt-3">@region Region</h4>
                            <div class="row">
                                @foreach (var game in Model.Round1Games.Where(g => g.Region == region))
                                {
                                    if (game.Team1Id.HasValue && game.Team2Id.HasValue)
                                    {
                                        <div class="col-md-6 mb-3">
                                            <div class="card">
                                                <div class="card-body">
                                                    <strong>Game @game.GameNumber</strong>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" 
                                                               name="GamePicks[@game.Id]" 
                                                               value="@game.Team1Id" 
                                                               id="game_@(game.Id)_team1" required>
                                                        <label class="form-check-label" for="game_@(game.Id)_team1">
                                                            @game.Team1?.Name
                                                        </label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" 
                                                               name="GamePicks[@game.Id]" 
                                                               value="@game.Team2Id" 
                                                               id="game_@(game.Id)_team2" required>
                                                        <label class="form-check-label" for="game_@(game.Id)_team2">
                                                            @game.Team2?.Name
                                                        </label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Round 2 -->
                <div class="card mb-4">
                    <div class="card-header bg-success text-white">
                        <h3>Round 2 - Round of 32</h3>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Pick the winners advancing from Round 1</p>
                        @foreach (var region in new[] { "East", "West", "South", "Midwest" })
                        {
                            <h4 class="mt-3">@region Region</h4>
                            <div class="row">
                                @foreach (var game in Model.Round2Games.Where(g => g.Region == region))
                                {
                                    <div class="col-md-6 mb-3">
                                        <div class="card">
                                            <div class="card-body">
                                                <strong>Game @game.GameNumber</strong>
                                                <p class="text-muted small">Select from your Round 1 winners</p>
                                                <select name="GamePicks[@game.Id]" class="form-select" required>
                                                    <option value="">-- Select Winner --</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Round 3 -->
                <div class="card mb-4">
                    <div class="card-header bg-warning">
                        <h3>Round 3 - Sweet 16</h3>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Pick the winners advancing from Round 2</p>
                        @foreach (var region in new[] { "East", "West", "South", "Midwest" })
                        {
                            <h4 class="mt-3">@region Region</h4>
                            <div class="row">
                                @foreach (var game in Model.Round3Games.Where(g => g.Region == region))
                                {
                                    <div class="col-md-6 mb-3">
                                        <div class="card">
                                            <div class="card-body">
                                                <strong>Game @game.GameNumber</strong>
                                                <select name="GamePicks[@game.Id]" class="form-select" required>
                                                    <option value="">-- Select Winner --</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Round 4 -->
                <div class="card mb-4">
                    <div class="card-header bg-danger text-white">
                        <h3>Round 4 - Elite 8</h3>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Pick the winners advancing from Sweet 16</p>
                        @foreach (var region in new[] { "East", "West", "South", "Midwest" })
                        {
                            <h4 class="mt-3">@region Region</h4>
                            @foreach (var game in Model.Round4Games.Where(g => g.Region == region))
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="card">
                                        <div class="card-body">
                                            <strong>Game @game.GameNumber</strong>
                                            <select name="GamePicks[@game.Id]" class="form-select" required>
                                                <option value="">-- Select Winner --</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- Round 5 -->
                <div class="card mb-4">
                    <div class="card-header bg-info text-white">
                        <h3>Round 5 - Final Four</h3>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Pick the winners advancing from Elite 8</p>
                        <div class="row">
                            @foreach (var game in Model.Round5Games)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="card">
                                        <div class="card-body">
                                            <strong>Game @game.GameNumber</strong>
                                            <select name="GamePicks[@game.Id]" class="form-select" required>
                                                <option value="">-- Select Winner --</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Round 6 -->
                <div class="card mb-4">
                    <div class="card-header bg-dark text-white">
                        <h3>Round 6 - Championship</h3>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Pick the national champion from Final Four winners</p>
                        @foreach (var game in Model.Round6Games)
                        {
                            <div class="card">
                                <div class="card-body">
                                    <strong>Championship Game</strong>
                                    <select name="GamePicks[@game.Id]" class="form-select" required>
                                        <option value="">-- Select Champion --</option>
                                    </select>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg">Submit Bracket</button>
                </div>
            }
        </form>
    }
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Simple cascading logic - in a real app you'd make this more robust
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Bracket form loaded');
        });
    </script>
}
