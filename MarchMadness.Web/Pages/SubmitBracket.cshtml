@page
@using MarchMadness.Web.Pages.Shared
@model MarchMadness.Web.Pages.SubmitBracketModel
@{
    ViewData["Title"] = $"Submit {(Model.Sport == "basketball-men" ? "Men's" : "Women's")} Bracket";
    ViewData["FullWidth"] = true;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@ViewData["Title"]</h1>
        <div class="btn-group">
            <a href="?sport=basketball-men" class="btn @(Model.Sport == "basketball-men" ? "btn-primary" : "btn-outline-primary")">Men's</a>
            <a href="?sport=basketball-women" class="btn @(Model.Sport == "basketball-women" ? "btn-info" : "btn-outline-info")">Women's</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error!</strong> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.IsNameVerified)
    {
        <!-- Name Entry Form -->
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h3 class="card-title text-center mb-4">Enter Your Name</h3>
                        <p class="text-center text-muted mb-4">Enter your name to get started. Each person can only submit one bracket per tournament.</p>

                        <form method="post" asp-page-handler="VerifyName">
                            <input type="hidden" asp-for="Sport" />

                            <div class="mb-3">
                                <label asp-for="UserName" class="form-label">Your Name</label>
                                <input asp-for="UserName" class="form-control form-control-lg" placeholder="Enter your full name" required autofocus />
                                <div class="form-text">This name will be displayed on the standings page.</div>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">Continue to Bracket</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="text-center mt-3">
                    <small class="text-muted">
                        <i class="bi bi-info-circle"></i> If you already submitted a bracket, you'll need to use a different name.
                    </small>
                </div>
            </div>
        </div>
    }
    else if (!Model.HasGames)
    {
        <div class="alert alert-warning">
            <strong>Tournament not set up yet.</strong>
            <p>The bracket data needs to be synced from the API. Please contact Sophie.</p>
        </div>
    }
    else
    {
        <!-- Bracket Form (only shown after name verification) -->
        <div class="alert alert-success mb-3">
            <strong>Welcome, @Model.UserName!</strong> Fill out your bracket below and click Submit when finished.
        </div>
        <form method="post" asp-page-handler="SubmitBracket" id="bracketForm">
            <input type="hidden" asp-for="Sport" />
            <input type="hidden" asp-for="UserName" />

            <div id="validationMessage" class="alert alert-danger d-none mb-3" role="alert">
                <strong>Incomplete Bracket!</strong> Please make selections for all highlighted games below.
            </div>

            @{
                var allGames = Model.AllPossibleGames.OrderBy(g => g.Round).ThenBy(g => g.BracketPositionId).ToList();
                var leftRoundOrder = new[] { 2, 3, 4, 5 };
                var rightRoundOrder = new[] { 5, 4, 3, 2 };
                var finalBracketOrder = new[] { 601, 701, 602 };

                var leftPanels = new[] { "South", "West" }
                    .Select(regionName => new BracketRegionPanelModel
                    {
                        RegionName = regionName,
                        Games = allGames.Where(g => string.Equals(g.Region, regionName, StringComparison.OrdinalIgnoreCase)).ToList(),
                        RoundOrder = leftRoundOrder,
                        PanelClass = "region-panel-left"
                    })
                    .Where(p => p.Games.Any())
                    .ToList();

                var rightPanels = new[] { "East", "Midwest" }
                    .Select(regionName => new BracketRegionPanelModel
                    {
                        RegionName = regionName,
                        Games = allGames.Where(g => string.Equals(g.Region, regionName, StringComparison.OrdinalIgnoreCase)).ToList(),
                        RoundOrder = rightRoundOrder,
                        PanelClass = "region-panel-right"
                    })
                    .Where(p => p.Games.Any())
                    .ToList();

                BracketFinalPanelModel? finalPanel = new BracketFinalPanelModel
                {
                    Games = allGames
                        .Where(g => string.Equals(g.Region, "Final", StringComparison.OrdinalIgnoreCase)
                                 || string.Equals(g.Region, "Finals", StringComparison.OrdinalIgnoreCase)
                                 || string.Equals(g.Region, "Region6", StringComparison.OrdinalIgnoreCase))
                        .OrderBy(g => Array.IndexOf(finalBracketOrder, g.BracketPositionId))
                        .ThenBy(g => g.BracketPositionId)
                        .ToList()
                };
            }

            <div class="card w-100 bracket-shell" style="overflow: auto;">
                <div class="card-body p-0">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 p-3">

                        <div class="d-flex align-items-center gap-2">
                            <div class="small text-muted">Scroll to navigate · Use zoom controls for detail</div>
                            <button type="button" id="autofillBtn" class="btn btn-sm btn-outline-warning" title="Randomly fill all remaining picks">
                                🎲 Autofill
                            </button>
                        </div>
                        <div class="btn-group btn-group-sm" role="group" aria-label="Bracket zoom controls">
                            <button type="button" id="zoomOutBtn" class="btn btn-outline-secondary">-</button>
                            <button type="button" id="zoomResetBtn" class="btn btn-outline-secondary">100%</button>
                            <button type="button" id="zoomInBtn" class="btn btn-outline-secondary">+</button>
                        </div>
                    </div>

                    <div class="bracket-scroll" id="bracketScroll">
                        <div class="bracket-zoom-surface" id="bracketZoomSurface">
                            <div class="row row-cols-3 align-items-start flex-nowrap gx-3 bracket-board">
                                <div class="col bracket-board-col">
                                    @foreach (var panel in leftPanels)
                                    {
                                        <partial name="_BracketRegionPanel" model="panel" />
                                    }
                                </div>

                                <div class="col bracket-board-col bracket-board-col-final">
                                    <partial name="_BracketFinalPanel" model="finalPanel" />
                                </div>

                                <div class="col bracket-board-col">
                                    @foreach (var panel in rightPanels)
                                    {
                                        <partial name="_BracketRegionPanel" model="panel" />
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2 my-4">
                <button type="button" id="submitBtn" class="btn btn-lg @(Model.Sport == "basketball-men" ? "btn-primary" : "btn-info")">
                    Submit Bracket
                </button>
            </div>

        </form>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('bracketForm');
            const submitBtn = document.getElementById('submitBtn');
            const autofillBtn = document.getElementById('autofillBtn');
            const validationMessage = document.getElementById('validationMessage');
            const bracketScroll = document.getElementById('bracketScroll');
            const bracketZoomSurface = document.getElementById('bracketZoomSurface');
            const zoomInBtn = document.getElementById('zoomInBtn');
            const zoomOutBtn = document.getElementById('zoomOutBtn');
            const zoomResetBtn = document.getElementById('zoomResetBtn');
            const bracketBoard = bracketZoomSurface?.querySelector('.bracket-board');

            if (!form || !submitBtn || !validationMessage || !bracketScroll || !bracketZoomSurface || !bracketBoard) {
                return;
            }

            // ── Zoom ──
            let currentZoom = 1;
            let minZoom = 0.35;
            const maxZoom = 1.6;
            const zoomStep = 0.1;
            const baseBoardWidth = Math.max(bracketBoard.scrollWidth, 1);

            function getFitZoom() {
                const horizontalFit = bracketScroll.clientWidth / baseBoardWidth;
                return Math.max(0.2, Math.min(1, horizontalFit));
            }

            function applyZoom() {
                minZoom = getFitZoom();
                currentZoom = Math.max(minZoom, Math.min(maxZoom, Math.round(currentZoom * 100) / 100));
                bracketZoomSurface.style.zoom = `${currentZoom}`;
                bracketZoomSurface.style.transform = 'none';
                bracketZoomSurface.style.width = `${baseBoardWidth}px`;
                if (zoomResetBtn) zoomResetBtn.textContent = `${Math.round(currentZoom * 100)}%`;
            }

            function fitToPanel() {
                currentZoom = getFitZoom();
                applyZoom();
                bracketScroll.scrollLeft = 0;
                bracketScroll.scrollTop = 0;
            }

            zoomInBtn?.addEventListener('click', () => { currentZoom += zoomStep; applyZoom(); });
            zoomOutBtn?.addEventListener('click', () => { currentZoom -= zoomStep; applyZoom(); });
            zoomResetBtn?.addEventListener('click', () => { fitToPanel(); });

            window.addEventListener('resize', () => {
                const fitZoom = getFitZoom();
                if (currentZoom < fitZoom) currentZoom = fitZoom;
                applyZoom();
            });

            bracketScroll.addEventListener('wheel', function(e) {
                if (!e.ctrlKey) return;
                e.preventDefault();
                currentZoom += e.deltaY < 0 ? zoomStep : -zoomStep;
                applyZoom();
            }, { passive: false });

            fitToPanel();

            // ── Game position map ──
            const bracketPositionMap = new Map();
            const games = document.querySelectorAll('.bracket-game');

            games.forEach(game => {
                const position = parseInt(game.dataset.bracketPosition);
                if (!isNaN(position)) bracketPositionMap.set(position, game);
            });

            // ── Slot determination ──
            function determineTargetSlot(sourcePosition, targetPosition) {
                const feeders = [];
                games.forEach(g => {
                    const victorPos = parseInt(g.dataset.victorPosition);
                    const srcPos = parseInt(g.dataset.bracketPosition);
                    if (victorPos === targetPosition) feeders.push(srcPos);
                });

                if (feeders.length === 2) {
                    feeders.sort((a, b) => a - b);
                    return sourcePosition === feeders[0] ? 1 : 2;
                }

                return sourcePosition < targetPosition ? 1 : 2;
            }

            // ── Radio change handler ──
            function handleRadioChange(radio) {
                const gameDiv = radio.closest('.bracket-game');
                if (!gameDiv) return;

                const victorPosition = parseInt(gameDiv.dataset.victorPosition);
                const selectedTeamId = parseInt(radio.value);
                const sourcePosition = parseInt(gameDiv.dataset.bracketPosition);

                gameDiv.classList.remove('error');
                const matchup = gameDiv.querySelector('.matchup');
                if (matchup) matchup.classList.remove('error');

                if (victorPosition && bracketPositionMap.has(victorPosition)) {
                    updateNextRoundGame(victorPosition, sourcePosition, selectedTeamId, gameDiv);
                }
            }

            document.querySelectorAll('.team-radio').forEach(radio => {
                radio.addEventListener('change', function() { handleRadioChange(this); });
            });

            // ── Propagate winner to next round ──
            function updateNextRoundGame(victorPosition, sourcePosition, teamId, sourceGame) {
                const nextGame = bracketPositionMap.get(victorPosition);
                if (!nextGame) return;

                const matchup = nextGame.querySelector('.matchup');
                if (!matchup) return;

                const targetSlot = determineTargetSlot(sourcePosition, victorPosition);
                const teamOption = sourceGame.querySelector(`[data-team-id="${teamId}"]`);
                if (!teamOption) return;

                const teamName = teamOption.dataset.teamName || '';
                const teamSeed = teamOption.dataset.teamSeed || '';
                const teamLogo = teamOption.dataset.teamLogo || '';
                const teamLogoSrc = teamLogo ? `https://ncaa.com${teamLogo}` : '';

                const teamOptions = matchup.querySelectorAll('.team-option');
                const targetOption = teamOptions[targetSlot - 1];

                if (targetOption) {
                    const gameId = nextGame.dataset.gameId;

                    targetOption.classList.remove('placeholder');
                    targetOption.dataset.teamId = teamId;
                    targetOption.dataset.teamName = teamName;
                    targetOption.dataset.teamSeed = teamSeed;
                    targetOption.dataset.teamLogo = teamLogo;
                    targetOption.dataset.slot = targetSlot;

                    targetOption.innerHTML = `
                        <input type="radio"
                               name="GamePicks[${gameId}]"
                               value="${teamId}"
                               id="game_${gameId}_team${targetSlot}"
                               class="form-check-input team-radio"
                               data-game-id="${gameId}" />
                        <label for="game_${gameId}_team${targetSlot}" class="form-check-label w-100 ms-2">
                            <span class="d-flex align-items-center gap-2">
                                ${teamLogoSrc ? `<img src="${teamLogoSrc}" alt="${teamName}" class="team-logo" onerror="this.style.display='none'" />` : ''}
                                ${teamSeed ? `<span class="small text-muted">${teamSeed}</span>` : ''}
                                <span>${teamName}</span>
                            </span>
                        </label>
                    `;

                    const newRadio = targetOption.querySelector('.team-radio');
                    if (newRadio) {
                        newRadio.addEventListener('change', function() { handleRadioChange(this); });
                    }

                    const allOptions = matchup.querySelectorAll('.team-option');
                    const allPopulated = Array.from(allOptions).every(opt => !opt.classList.contains('placeholder'));
                    if (allPopulated) matchup.classList.remove('tbd');
                }

                const nextGameRadios = nextGame.querySelectorAll('.team-radio');
                nextGameRadios.forEach(r => r.checked = false);

                const nextVictorPosition = parseInt(nextGame.dataset.victorPosition);
                if (nextVictorPosition && bracketPositionMap.has(nextVictorPosition)) {
                    clearCascadingGames(nextVictorPosition);
                }
            }

            // ── Clear downstream ──
            function clearCascadingGames(startPosition) {
                const game = bracketPositionMap.get(startPosition);
                if (!game) return;

                game.querySelectorAll('.team-radio').forEach(r => r.checked = false);

                const matchup = game.querySelector('.matchup');
                if (matchup) {
                    const teamOptions = matchup.querySelectorAll('.team-option');
                    teamOptions.forEach(opt => {
                        opt.classList.add('placeholder');
                        opt.innerHTML = '<span class="team-name">TBD</span>';
                        opt.dataset.teamId = '';
                        opt.dataset.teamName = '';
                        opt.dataset.teamSeed = '';
                        opt.dataset.teamLogo = '';
                    });
                    matchup.classList.add('tbd');
                }

                const victorPosition = parseInt(game.dataset.victorPosition);
                if (victorPosition && bracketPositionMap.has(victorPosition)) {
                    clearCascadingGames(victorPosition);
                }
            }

            // ── Autofill ──
            autofillBtn?.addEventListener('click', function(e) {
                e.preventDefault();

                // Process games round-by-round so feeder picks propagate properly
                const maxRound = 7;
                for (let round = 2; round <= maxRound; round++) {
                    games.forEach(game => {
                        const gameRound = parseInt(game.dataset.round);
                        if (gameRound !== round) return;

                        // Skip if already picked
                        const existingRadios = game.querySelectorAll('.team-radio');
                        const alreadyPicked = Array.from(existingRadios).some(r => r.checked);
                        if (alreadyPicked) return;

                        // Gather available (non-placeholder) team options
                        const opts = game.querySelectorAll('.team-option:not(.placeholder)');
                        if (opts.length < 2) return; // both teams must be populated

                        // Pick a random team option
                        const randomIdx = Math.floor(Math.random() * opts.length);
                        const chosenOpt = opts[randomIdx];
                        const radio = chosenOpt.querySelector('.team-radio');
                        if (radio) {
                            radio.checked = true;
                            handleRadioChange(radio);
                        }
                    });
                }

            });

            // ── Submit validation ──
            submitBtn.addEventListener('click', function(e) {
                e.preventDefault();

                document.querySelectorAll('.bracket-game.error, .matchup.error').forEach(el => {
                    el.classList.remove('error');
                });
                validationMessage.classList.add('d-none');

                let hasErrors = false;
                games.forEach(game => {
                    const matchup = game.querySelector('.matchup');
                    if (matchup && !matchup.classList.contains('tbd')) {
                        const radios = game.querySelectorAll('.team-radio');
                        const hasSelection = Array.from(radios).some(r => r.checked);

                        if (!hasSelection) {
                            game.classList.add('error');
                            matchup.classList.add('error');
                            hasErrors = true;
                        }
                    }
                });

                if (hasErrors) {
                    validationMessage.classList.remove('d-none');
                    const firstError = document.querySelector('.bracket-game.error');
                    if (firstError) {
                        firstError.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'center' });
                    }
                } else if (confirm('Are you sure you want to submit your bracket? You cannot change it after submission.')) {
                    form.submit();
                }
            });
        });
    </script>
}
