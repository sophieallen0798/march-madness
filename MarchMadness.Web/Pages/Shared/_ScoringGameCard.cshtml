@using MarchMadness.Web.Pages.Shared
@model ScoringGameCardModel

<div class="bracket-game scoring-game" data-bracket-position="@Model.BracketPositionId">
    <div class="matchup card @(Model.Team1 == null && Model.Team2 == null ? "tbd" : "")">
        <div class="card-body p-0">
            @* Team 1 *@
            @{
                var pick1Class = Model.GetPickCssClass(Model.Team1?.Id);
                var isPicked1 = Model.IsPickedTeam(Model.Team1?.Id);
            }
            <div class="team-option-scoring d-flex align-items-center px-3 py-2 border-bottom @pick1Class @(isPicked1 ? "picked" : "")">
                @if (Model.Team1 == null)
                {
                    <span class="small text-muted fst-italic">TBD</span>
                }
                else
                {
                    <span class="d-flex align-items-center gap-2 w-100">
                        @if (!string.IsNullOrEmpty(Model.Team1.LogoUrl))
                        {
                            <img src="https://ncaa.com@(Model.Team1.LogoUrl)" alt="@Model.Team1.NameShort" class="team-logo" onerror="this.style.display='none'" />
                        }
                        <span class="text-muted small">@Model.Team1.Seed</span>
                        <span class="@(isPicked1 ? "fw-bold" : "")">@Model.Team1.NameShort</span>
                        @if (isPicked1)
                        {
                            <span class="ms-auto badge bg-secondary">&#10003;</span>
                        }
                    </span>
                }
            </div>

            @* Team 2 *@
            @{
                var pick2Class = Model.GetPickCssClass(Model.Team2?.Id);
                var isPicked2 = Model.IsPickedTeam(Model.Team2?.Id);
            }
            <div class="team-option-scoring d-flex align-items-center px-3 py-2 @pick2Class @(isPicked2 ? "picked" : "")">
                @if (Model.Team2 == null)
                {
                    <span class="small text-muted fst-italic">TBD</span>
                }
                else
                {
                    <span class="d-flex align-items-center gap-2 w-100">
                        @if (!string.IsNullOrEmpty(Model.Team2.LogoUrl))
                        {
                            <img src="https://ncaa.com@(Model.Team2.LogoUrl)" alt="@Model.Team2.NameShort" class="team-logo" onerror="this.style.display='none'" />
                        }
                        <span class="text-muted small">@Model.Team2.Seed</span>
                        <span class="@(isPicked2 ? "fw-bold" : "")">@Model.Team2.NameShort</span>
                        @if (isPicked2)
                        {
                            <span class="ms-auto badge bg-secondary">&#10003;</span>
                        }
                    </span>
                }
            </div>

            @* Game status: show scheduled time or live indicator *@
            @if (!Model.ActualWinnerId.HasValue && Model.StartTime.HasValue)
            {
                <div class="text-center small text-muted py-1 border-top bg-light">
                    @Model.StartTime.Value.ToString("MMM d, h:mm tt")
                </div>
            }
            else if (!Model.ActualWinnerId.HasValue && string.Equals(Model.GameState, "live", StringComparison.OrdinalIgnoreCase))
            {
                <div class="text-center small fw-bold text-danger py-1 border-top bg-light">
                    LIVE
                </div>
            }
        </div>
    </div>
</div>
