@page
@model MarchMadness.Web.Pages.StandingsModel
@{
    ViewData["Title"] = "Standings";
}

<div class="container mt-4">
    <h1>March Madness Standings</h1>

    @if (!Model.Standings.Any())
    {
        <div class="alert alert-info">
            <strong>No brackets submitted yet.</strong>
            <p>Be the first to submit your bracket!</p>
            <a href="/SubmitBracket" class="btn btn-primary">Submit Bracket</a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Rank</th>
                                <th>Bracket Name</th>
                                <th>User</th>
                                <th>Points</th>
                                <th>Submitted</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var standing in Model.Standings)
                            {
                                <tr class="@(standing.Rank == 1 ? "table-warning" : "")">
                                    <td>
                                        @if (standing.Rank == 1)
                                        {
                                            <strong>🏆 @standing.Rank</strong>
                                        }
                                        else if (standing.Rank == 2)
                                        {
                                            <strong>🥈 @standing.Rank</strong>
                                        }
                                        else if (standing.Rank == 3)
                                        {
                                            <strong>🥉 @standing.Rank</strong>
                                        }
                                        else
                                        {
                                            @standing.Rank
                                        }
                                    </td>
                                    <td>@standing.BracketName</td>
                                    <td>@standing.UserName</td>
                                    <td><strong>@standing.TotalPoints</strong></td>
                                    <td>@standing.SubmittedDate.ToString("MMM dd, yyyy h:mm tt")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                <strong>Scoring:</strong> Round 1 = 1 pt, Round 2 = 2 pts, Round 3 = 4 pts, Round 4 = 8 pts, Round 5 = 16 pts, Championship = 32 pts
            </p>
        </div>
    }
</div>
