@page
@model MarchMadness.Web.Pages.StandingsModel
@{
    ViewData["Title"] = "Standings";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>March Madness Standings</h1>
        <div class="btn-group">
            <a href="?sport=basketball-men" class="btn @(Model.Sport == "basketball-men" ? "btn-primary" : "btn-outline-primary")">Men's</a>
            <a href="?sport=basketball-women" class="btn @(Model.Sport == "basketball-women" ? "btn-info" : "btn-outline-info")">Women's</a>
        </div>
    </div>

    @if (!Model.Standings.Any())
    {
        <div class="alert alert-info">
            <strong>No brackets submitted yet for @(Model.Sport == "basketball-men" ? "Men's" : "Women's") Basketball.</strong>
            <p>Be the first to submit your bracket!</p>
            <a href="/SubmitBracket?sport=@Model.Sport" class="btn @(Model.Sport == "basketball-men" ? "btn-primary" : "btn-info")">Submit Bracket</a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Rank</th>
                                <th>Bracket Name</th>
                                <th>User</th>
                                <th>Points</th>
                                <th>Submitted</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var standing in Model.Standings)
                            {
                                <tr class="@(standing.Rank == 1 ? "table-warning" : "")">
                                    <td>
                                        @if (standing.Rank == 1)
                                        {
                                            <strong>🏆 @standing.Rank</strong>
                                        }
                                        else if (standing.Rank == 2)
                                        {
                                            <strong>🥈 @standing.Rank</strong>
                                        }
                                        else if (standing.Rank == 3)
                                        {
                                            <strong>🥉 @standing.Rank</strong>
                                        }
                                        else
                                        {
                                            @standing.Rank
                                        }
                                    </td>
                                    <td>@standing.BracketName</td>
                                    <td>@standing.UserName</td>
                                    <td><strong>@standing.TotalPoints</strong></td>
                                    <td>@standing.SubmittedDate.ToString("MMM dd, yyyy h:mm tt")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                <strong>Scoring:</strong> Points double each round (1, 2, 4, 8, 16, 32)
            </p>
        </div>
    }
</div>
