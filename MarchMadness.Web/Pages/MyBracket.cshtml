@page
@using MarchMadness.Web.Pages.Shared
@model MarchMadness.Web.Pages.MyBracketModel
@{
    ViewData["Title"] = Model.HasBracket
        ? $"{Model.UserName}'s {(Model.Sport == "basketball-men" ? "Men's" : "Women's")} Bracket"
        : "View Bracket";
    ViewData["FullWidth"] = true;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@ViewData["Title"]</h1>
        <div class="btn-group">
            <a href="?sport=basketball-men" class="btn @(Model.Sport == "basketball-men" ? "btn-primary" : "btn-outline-primary")">Men's</a>
            <a href="?sport=basketball-women" class="btn @(Model.Sport == "basketball-women" ? "btn-info" : "btn-outline-info")">Women's</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error!</strong> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.HasBracket)
    {
        @if (Model.AvailableBrackets.Any())
        {
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="card shadow-sm">
                        <div class="card-body p-4">
                            <h3 class="card-title text-center mb-3">Select a Bracket to View</h3>
                            <p class="text-center text-muted mb-4">Choose a submitted bracket to see picks and scoring.</p>
                            <div class="list-group">
                                @foreach (var bracket in Model.AvailableBrackets)
                                {
                                    <a href="?sport=@Model.Sport&bracketId=@bracket.Id"
                                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                        <span class="fw-semibold">@bracket.UserName</span>
                                        <span class="text-muted small">@bracket.Name</span>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <strong>No brackets submitted yet.</strong>
                <p>Be the first to <a href="/SubmitBracket?sport=@Model.Sport">submit a bracket</a>!</p>
            </div>
        }
    }
    else
    {
        var scoringGames = Model.ScoringGames;
        var leftRoundOrder = new[] { 2, 3, 4, 5 };
        var rightRoundOrder = new[] { 5, 4, 3, 2 };
        var finalBracketOrder = new[] { 601, 701, 602 };

        var leftPanels = new[] { "South", "West" }
            .Select(regionName => new ScoringRegionPanelModel
            {
                RegionName = regionName,
                Games = scoringGames.Where(g => string.Equals(g.Region, regionName, StringComparison.OrdinalIgnoreCase)).ToList(),
                RoundOrder = leftRoundOrder,
                PanelClass = "region-panel-left"
            })
            .Where(p => p.Games.Any())
            .ToList();

        var rightPanels = new[] { "East", "Midwest" }
            .Select(regionName => new ScoringRegionPanelModel
            {
                RegionName = regionName,
                Games = scoringGames.Where(g => string.Equals(g.Region, regionName, StringComparison.OrdinalIgnoreCase)).ToList(),
                RoundOrder = rightRoundOrder,
                PanelClass = "region-panel-right"
            })
            .Where(p => p.Games.Any())
            .ToList();

        var finalPanel = new ScoringFinalPanelModel
        {
            Games = scoringGames
                .Where(g => string.Equals(g.Region, "Final", StringComparison.OrdinalIgnoreCase)
                         || string.Equals(g.Region, "Finals", StringComparison.OrdinalIgnoreCase)
                         || string.Equals(g.Region, "Region6", StringComparison.OrdinalIgnoreCase))
                .OrderBy(g => Array.IndexOf(finalBracketOrder, g.BracketPositionId))
                .ThenBy(g => g.BracketPositionId)
                .ToList()
        };

        <!-- Bracket selector and legend -->
        <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
            <label class="form-label mb-0 fw-semibold">Viewing:</label>
            <select class="form-select form-select-sm" style="max-width: 300px;"
                    onchange="window.location.href='?sport=@Model.Sport&bracketId=' + this.value">
                @foreach (var bracket in Model.AvailableBrackets)
                {
                    if (bracket.Id == Model.UserBracket!.Id)
                    {
                        <option value="@bracket.Id" selected>@bracket.UserName</option>
                    }
                    else
                    {
                        <option value="@bracket.Id">@bracket.UserName</option>
                    }
                }
            </select>
            <div class="ms-auto d-flex gap-2 align-items-center">
                <span class="badge-legend pick-correct-legend">&nbsp;</span> <small>Correct</small>
                <span class="badge-legend pick-incorrect-legend">&nbsp;</span> <small>Incorrect</small>
                <span class="badge-legend pick-pending-legend">&nbsp;</span> <small>Pending</small>
            </div>
        </div>

        <div class="card w-100 bracket-shell" style="overflow: auto;">
            <div class="card-body p-0">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 p-3">
                    <div class="small text-muted">Scroll to navigate &middot; Use zoom controls for detail</div>
                    <div class="btn-group btn-group-sm" role="group" aria-label="Bracket zoom controls">
                        <button type="button" id="zoomOutBtn" class="btn btn-outline-secondary">-</button>
                        <button type="button" id="zoomResetBtn" class="btn btn-outline-secondary">100%</button>
                        <button type="button" id="zoomInBtn" class="btn btn-outline-secondary">+</button>
                    </div>
                </div>

                <div class="bracket-scroll" id="bracketScroll">
                    <div class="bracket-zoom-surface" id="bracketZoomSurface">
                        <div class="row row-cols-3 align-items-start flex-nowrap gx-3 bracket-board">
                            <div class="col bracket-board-col">
                                @foreach (var panel in leftPanels)
                                {
                                    <partial name="_ScoringRegionPanel" model="panel" />
                                }
                            </div>

                            <div class="col bracket-board-col bracket-board-col-final">
                                <partial name="_ScoringFinalPanel" model="finalPanel" />
                            </div>

                            <div class="col bracket-board-col">
                                @foreach (var panel in rightPanels)
                                {
                                    <partial name="_ScoringRegionPanel" model="panel" />
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const bracketScroll = document.getElementById('bracketScroll');
            const bracketZoomSurface = document.getElementById('bracketZoomSurface');
            const zoomInBtn = document.getElementById('zoomInBtn');
            const zoomOutBtn = document.getElementById('zoomOutBtn');
            const zoomResetBtn = document.getElementById('zoomResetBtn');
            const bracketBoard = bracketZoomSurface?.querySelector('.bracket-board');

            if (!bracketScroll || !bracketZoomSurface || !bracketBoard) return;

            let currentZoom = 1;
            let minZoom = 0.35;
            const maxZoom = 1.6;
            const zoomStep = 0.1;
            const baseBoardWidth = Math.max(bracketBoard.scrollWidth, 1);

            function getFitZoom() {
                const horizontalFit = bracketScroll.clientWidth / baseBoardWidth;
                return Math.max(0.2, Math.min(1, horizontalFit));
            }

            function applyZoom() {
                minZoom = getFitZoom();
                currentZoom = Math.max(minZoom, Math.min(maxZoom, Math.round(currentZoom * 100) / 100));
                bracketZoomSurface.style.zoom = `${currentZoom}`;
                bracketZoomSurface.style.transform = 'none';
                bracketZoomSurface.style.width = `${baseBoardWidth}px`;
                if (zoomResetBtn) zoomResetBtn.textContent = `${Math.round(currentZoom * 100)}%`;
            }

            function fitToPanel() {
                currentZoom = getFitZoom();
                applyZoom();
                bracketScroll.scrollLeft = 0;
                bracketScroll.scrollTop = 0;
            }

            zoomInBtn?.addEventListener('click', () => { currentZoom += zoomStep; applyZoom(); });
            zoomOutBtn?.addEventListener('click', () => { currentZoom -= zoomStep; applyZoom(); });
            zoomResetBtn?.addEventListener('click', () => { fitToPanel(); });

            window.addEventListener('resize', () => {
                const fitZoom = getFitZoom();
                if (currentZoom < fitZoom) currentZoom = fitZoom;
                applyZoom();
            });

            bracketScroll.addEventListener('wheel', function (e) {
                if (!e.ctrlKey) return;
                e.preventDefault();
                currentZoom += e.deltaY < 0 ? zoomStep : -zoomStep;
                applyZoom();
            }, { passive: false });

            fitToPanel();
        });
    </script>
}
